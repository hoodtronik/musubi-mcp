# musubi-mcp environment configuration
# Copy to .env and fill in values. Never commit the real .env.

# REQUIRED — absolute path to the Musubi Tuner checkout.
# All scripts are executed from this directory as cwd, because
# Musubi's training scripts use relative imports.
MUSUBI_TUNER_DIR=

# REQUIRED for real work — Python interpreter with Musubi Tuner
# and all its training deps (torch+CUDA, accelerate, diffusers, ...).
# If unset, falls back to sys.executable, which only works when the
# MCP server is running inside Musubi's own venv.
MUSUBI_PYTHON=

# OPTIONAL — accelerate launcher. Defaults to "accelerate" on PATH of
# MUSUBI_PYTHON's venv. Override if you need a specific binary.
# MUSUBI_ACCELERATE=

# OPTIONAL — API keys forwarded to subprocesses when set. Used by
# captioning (Qwen VL) and future provider-backed tools.
# GEMINI_API_KEY=
# REPLICATE_API_TOKEN=
# HF_TOKEN=
